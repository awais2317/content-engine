## Example environment file for Boston's Studio
# Copy to .env and fill values

# App
STORAGE_DIR=/opt/bostons-studio/storage
PORT=8080

# Upload-Post (YouTube publish)
UPLOAD_POST_API_KEY=
UPLOAD_POST_USERNAME=
UPLOAD_POST_ENABLED=false

# Copilot/OpenClaw proxy (already on same VPS)
OPENAI_BASE_URL=http://127.0.0.1:4141/v1

# Azure/Edge TTS (optional)
AZURE_TTS_KEY=
AZURE_TTS_REGION=
