[Unit]
Description=Boston's Studio - Backend (FastAPI / Uvicorn)
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/bostons-studio
EnvironmentFile=/opt/bostons-studio/.env
ExecStart=/opt/bostons-studio/.venv/bin/uvicorn app.asgi:app --host 127.0.0.1 --port 8080 --workers 1
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
